# ---------------------------------------------------------------
# Microwork Hunter — example environment
# Copy to `.env` for local dev, or set as GitHub Actions secrets.
# NEVER commit real values.
# ---------------------------------------------------------------

# === LLM APIs (at least one required for non-dry-run mode) ===
GEMINI_API_KEY=
GROQ_API_KEY=

# === Browser ===
# Options: obscura | playwright | auto
BROWSER_TYPE=auto
OBSCURA_PORT=9222

# === Task settings ===
MAX_PARALLEL_TASKS=5
MIN_REWARD_USD=0.10
MAX_TASK_TIME_MIN=30
# true = dry-run (default, safe), false = real submissions
DRY_RUN=true

# === Social media tasks (HIGH RISK — read comment before enabling) ===
# When true, the bot will NOT auto-reject FB/IG/TikTok/Twitter/YouTube/etc.
# tasks. You MUST also provide cookies for each social platform via separate
# secrets (COOKIES_FACEBOOK, COOKIES_INSTAGRAM, COOKIES_TIKTOK, etc.).
# WARNING: social platforms aggressively ban automated accounts. Use only
# with dedicated burner accounts you can afford to lose.
ENABLE_SOCIAL_TASKS=false

# === Payment (optional, for platforms that ask payout address) ===
LTC_ADDRESS=

# === Cookies (base64-encoded JSON exported from Cookie-Editor) ===
# Leave empty to read from cookies/<platform>_cookies.json for local dev.
COOKIES_SPROUTGIGS=
COOKIES_COINPAYU=
COOKIES_TIMEBUCKS=
COOKIES_PRIZEREBEL=
COOKIES_COINTIPLY=

# === Social media cookies (only needed if ENABLE_SOCIAL_TASKS=true) ===
# Use dedicated burner accounts only — never your real accounts.
# COOKIES_FACEBOOK=
# COOKIES_INSTAGRAM=
# COOKIES_TIKTOK=
# COOKIES_TELEGRAM=
# COOKIES_TWITTER=
# COOKIES_YOUTUBE=
# COOKIES_REDDIT=
# COOKIES_LINKEDIN=
# COOKIES_DISCORD=
